# ========= Домэйн ба SSL (certbot) =========
DOMAIN=urgiin-mod.example.com
EMAIL=admin@example.com
# STAGING=1  # эхэлж туршихад (Let's Encrypt-ийн хязгаарт баригдахгүй). Бэлэн болмогц 0 болго.

# ========= Django =========
DEBUG=False
SECRET_KEY=ЭНД-УРТ-САНАМСАРГҮЙ-НУУЦ-ТҮЛХҮҮР-ОРУУЛ
ALLOWED_HOSTS=urgiin-mod.example.com,www.urgiin-mod.example.com
CSRF_TRUSTED_ORIGINS=https://urgiin-mod.example.com,https://www.urgiin-mod.example.com

# ========= PostgreSQL (өгөгдөл хадгалагдана) =========
POSTGRES_DB=familytree
POSTGRES_USER=familytree
POSTGRES_PASSWORD=ХҮЧТЭЙ-НУУЦ-ҮГ-ОРУУЛ

# ========= Админ superuser (эхний ачаалалтад автоматаар үүснэ) =========
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=АДМИН-НУУЦ-ҮГ-ОРУУЛ

# ========= Gunicorn =========
GUNICORN_WORKERS=3
